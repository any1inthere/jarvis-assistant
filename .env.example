# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# Get a bot token from Telegram's @BotFather:
#   1. Open Telegram and search for @BotFather
#   2. Send /newbot and follow the prompts
#   3. Paste the token below

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI — get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: change model (gpt-4o-mini is a good default — fast and cheap)
# OPENAI_MODEL=gpt-4o-mini

# Your timezone for reminders (Eastern)
TIMEZONE=America/New_York

# Google Calendar (optional paths)
# GOOGLE_CREDENTIALS_PATH=credentials/google_credentials.json
# GOOGLE_TOKEN_PATH=data/google_token.json

# Web dashboard (local network only — set on the Pi)
DASHBOARD_PASSWORD=choose-a-strong-password
DASHBOARD_SECRET_KEY=random-long-string-for-sessions
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000

# --- Future settings ---
# GHL_API_KEY=
